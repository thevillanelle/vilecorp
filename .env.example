# Supabase — VILE Corp project
# Get these from: supabase.com → your project → Settings → API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Stripe — for webhook signature verification and session retrieval
# STRIPE_SECRET_KEY: Stripe dashboard → Developers → API keys → Secret key
# STRIPE_WEBHOOK_SECRET: Stripe dashboard → Developers → Webhooks → your endpoint → Signing secret
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Resend — for sending purchase emails
# resend.com → API Keys
RESEND_API_KEY=re_...

# Your production URL — used to build PDF download links in emails
VITE_SITE_URL=https://vilecorp.com

# Copy this file to .env.local and fill in real values
# .env.local is gitignored — never commit real keys
